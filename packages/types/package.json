{
  "name": "@onyxhawk/types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./auth": {
      "import": "./dist/auth.js",
      "types": "./dist/auth.d.ts"
    },
    "./mpesa": {
      "import": "./dist/mpesa.js",
      "types": "./dist/mpesa.d.ts"
    },
    "./booking": {
      "import": "./dist/booking.js",
      "types": "./dist/booking.d.ts"
    },
    "./loyalty": {
      "import": "./dist/loyalty.js",
      "types": "./dist/loyalty.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  }
}
