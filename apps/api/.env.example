# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://onyxhawk:onyxhawk@localhost:5432/onyxhawk?schema=public

# Auth
JWT_SECRET=replace-me-with-a-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# CORS — comma-separated allowed browser origins (web + admin).
# Leave unset in local dev (reflects any origin). REQUIRED in production:
# CORS_ORIGIN=https://onyxhawkcleaningservice.com,https://admin.onyxhawkcleaningservice.com
CORS_ORIGIN=

# SMS (Africa's Talking). If credentials are missing AND NODE_ENV!=production,
# OTPs are logged to the server console for local dev.
AT_USERNAME=
AT_API_KEY=
SMS_SENDER_ID=ONYXHAWK

# M-Pesa Daraja (sandbox by default — flip to https://api.safaricom.co.ke for prod)
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://your-public-url.example.com/webhooks/mpesa/stk

# Object storage (Cloudflare R2 — S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=onyxhawk-media
R2_PUBLIC_URL=https://media.onyxhawk.example
