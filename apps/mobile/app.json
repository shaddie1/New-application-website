{
  "expo": {
    "name": "OnyxHawk",
    "slug": "onyxhawk",
    "scheme": "onyxhawk",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.onyxhawk.app"
    },
    "android": {
      "package": "com.onyxhawk.app",
      "adaptiveIcon": {
        "backgroundColor": "#F5F1E6"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "OnyxHawk needs photo access so the crew can attach before/after shots to a clean.",
          "cameraPermission": "OnyxHawk needs camera access so the crew can capture before/after shots on site."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://api.onyxhawkcleaningservice.com"
    }
  }
}
